// 1
document.getElementById('title').textContent = 'Добро пожаловать!';

// 2
const paragraphs = document.querySelectorAll('p');
alert('Количество параграфов: ' + paragraphs.length);

// 3
const link = document.querySelector('a');
link.href = 'https://google.com';
link.target = '_blank';

// 4
const firstParagraph = document.querySelector('p');
firstParagraph.style.color = 'red';
firstParagraph.style.fontSize = '20px';

// 5
const image = document.querySelector('img');
image.src = 'https://via.placeholder.com/150';

// 6
const ul = document.querySelector('ul');
for (let i = 1; i <= 5; i++) {
  const li = document.createElement('li');
  li.textContent = i;
  ul.appendChild(li);
}

// 7
const removeButton = document.querySelector('.remove-button');
removeButton.addEventListener('click', () => {
  const list = document.querySelector('ul');
  if (list.children.length > 0) {
    list.removeChild(list.lastElementChild);
  }
});

// 8
const changeBackgroundButton = document.querySelector('.change-background-button');
changeBackgroundButton.addEventListener('click', () => {
  document.body.style.backgroundColor = '#' + Math.floor(Math.random()*16777215).toString(16);
});
