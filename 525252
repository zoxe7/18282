// 7. Удаление элемента
const removeButton = document.querySelector('.remove-button'); // Добавьте класс кнопке в HTML
removeButton.addEventListener('click', () => {
  const list = document.querySelector('ul');
  if (list.children.length > 0) {
    list.removeChild(list.lastElementChild);
  }
});

// 8. Случайный фон
const changeBackgroundButton = document.querySelector('.change-background-button'); // Добавьте класс кнопке в HTML
changeBackgroundButton.addEventListener('click', () => {
  document.body.style.backgroundColor = '#' + Math.floor(Math.random()*16777215).toString(16);
});

// 9. Ввод и вывод текста
const input = document.querySelector('input');
const showTextButton = document.querySelector('.show-text-button'); // Добавьте класс кнопке в HTML
const outputParagraph = document.querySelector('.output-paragraph'); // Добавьте класс параграфу в HTML

showTextButton.addEventListener('click', () => {
  outputParagraph.textContent = input.value;
});

// 10. Скрыть/Показать текст
const toggleButton = document.querySelector('.toggle-button'); // Добавьте класс кнопке в HTML
const textBlock = document.querySelector('.text-block'); // Добавьте класс блоку в HTML

toggleButton.addEventListener('click', () => {
  if (textBlock.style.display === 'none') {
    textBlock.style.display = 'block';
  } else {
    textBlock.style.display = 'none';
  }
});

// 11. Счётчик
const countSpan = document.getElementById('count');
const incrementButton = document.querySelector('.increment-button'); // Добавьте класс кнопке в HTML
const decrementButton = document.querySelector('.decrement-button'); // Добавьте класс кнопке в HTML

let count = 0;

incrementButton.addEventListener('click', () => {
  count++;
  countSpan.textContent = count;
});

decrementButton.addEventListener('click', () => {
  count--;
  countSpan.textContent = count;
});

// 12. ToDo-лист
const todoInput = document.querySelector('.todo-input'); // Добавьте класс полю ввода в HTML
const addTodoButton = document.querySelector('.add-todo-button'); // Добавьте класс кнопке в HTML
const todoList = document.querySelector('.todo-list'); // Добавьте класс списку в HTML

addTodoButton.addEventListener('click', () => {
  const li = document.createElement('li');
  li.textContent = todoInput.value;
  todoList.appendChild(li);
  todoInput.value = '';
});

// 13. Переключение темы
const themeButton = document.querySelector('.theme-button'); // Добавьте класс кнопке в HTML

themeButton.addEventListener('click', () => {
  document.body.classList.toggle('dark');
});

// 14. Часы
const timeDiv = document.getElementById('time');

setInterval(() => {
  timeDiv.textContent = new Date().toLocaleTimeString();
}, 1000);

